# DATA LOADING
# ════════════════════════════════════════════════════════════════════════════════
@st.cache_data
def load_data():
    fp = os.path.join(os.path.dirname(os.path.abspath(__file__)),
        "Easy-to-use simplified balance sheet Financial diagnosis_Adidas.xlsx")
    if not os.path.exists(fp):
        st.error(f"Excel file not found at: {fp}")
        st.stop()

    df = pd.read_excel(fp, sheet_name="Balance Sheet", header=0)
    yrs = [2024, 2023, 2022, 2021]

    # Map rows by index (0-based after header)
    ROW = {
        "Intangible assets": 0, "PP&E": 1, "Other non-current assets": 2,
        "Total non-current assets": 3,
        "Inventories": 4, "Accounts receivable": 5, "Other current assets": 6,
        "Cash and cash equivalents": 7, "Total current assets": 8,
        "Total assets": 9,
        "Issued share capital": 10, "Capital & Other reserves": 11,
        "Equity portion of convertible debt": 12, "Retained earnings": 13,
        "Total equity": 14,
        "Borrowings non-current": 15, "Other non-current liabilities": 16,
        "Total non-current liabilities": 17,
        "Accounts payable": 18, "Bank overdraft": 19,
        "Borrowings current": 20, "Other current liabilities": 21,
        "Total current liabilities": 22, "Total equity and liabilities": 23,
    }

    d = {}
    for item, idx in ROW.items():
        d[item] = {yr: float(df.iloc[idx][yr]) if pd.notna(df.iloc[idx][yr]) else 0.0 for yr in yrs}
    return d, yrs

# ════════════════════════════════════════════════════════════════════════════════
# METRIC COMPUTATION — every balance-sheet-derivable metric from the course
# ════════════════════════════════════════════════════════════════════════════════
def compute(data, yrs):
    M = {}
    for y in yrs:
        fa  = data["Total non-current assets"][y]
        ca  = data["Total current assets"][y]
        ta  = data["Total assets"][y]
        se  = data["Total equity"][y]
        ltd = data["Borrowings non-current"][y]       # Long-Term Debt
        std = data["Borrowings current"][y]            # Short-Term Debt
        ncl = data["Total non-current liabilities"][y]
        cl  = data["Total current liabilities"][y]
        cash = data["Cash and cash equivalents"][y]
        inv  = data["Inventories"][y]
        ar   = data["Accounts receivable"][y]
        oca  = data["Other current assets"][y]
        ap   = data["Accounts payable"][y]
        od   = data["Bank overdraft"][y]
        ocl  = data["Other current liabilities"][y]
        oncl = data["Other non-current liabilities"][y]

        m = {}
        # ── Session 2: Core BS Aggregates ──────────────────────────────────────
        # Working Capital = Shareholders' Equity + Long-Term Liabilities − Fixed Assets
        m["WC"] = se + ncl - fa
        # Working Capital Need = Current Assets (excl. Cash) − Current Liab (excl. STD & Overdraft)
        m["WCN"] = (inv + ar + oca) - (ap + ocl)
        # Net Cash = WC − WCN  (verification: Cash − STD − Overdraft)
        m["Net Cash"] = m["WC"] - m["WCN"]
        m["Net Cash Check"] = cash - std - od
        # Net Debt = LTD + STD − Cash
        m["Net Debt"] = ltd + std - cash
        # Capital Employed = Fixed Assets + WCN
        m["Capital Employed"] = fa + m["WCN"]
        # Invested Capital = Shareholders' Equity + Net Debt
        m["Invested Capital"] = se + m["Net Debt"]
        # Difference due to Other Non-Current Liabilities
        m["CE-IC Gap"] = m["Capital Employed"] - m["Invested Capital"]

        # ── Session 6: Liquidity Ratios ────────────────────────────────────────
        # Current Ratio = Current Assets / Current Liabilities  (healthy: 1.5–2.0)
        m["Current Ratio"] = ca / cl if cl else None
        # Quick Ratio = (CA − Inventory) / CL  (healthy: 1.0–1.5)
        m["Quick Ratio"] = (ca - inv) / cl if cl else None
        # Cash Ratio = Cash / CL  (ideal: 0.5–1.0)
        m["Cash Ratio"] = cash / cl if cl else None

        # ── Session 6: Solvency & Leverage ─────────────────────────────────────
        td = ltd + std
        m["Total Debt"] = td
        # Total Debt Ratio = Total Debt / Total Assets  (good: 0.2–0.4)
        m["Total Debt Ratio"] = td / ta if ta else None
        # Debt-to-Equity = Total Debt / SE  (healthy: 0.5–1.0)
        m["D/E Ratio"] = td / se if se else None
        # Equity Multiplier = Total Assets / SE
        m["Equity Multiplier"] = ta / se if se else None
        # Verification: D/E should equal EM − 1
        # Note: EM − 1 = (TA − SE)/SE = Total Liabilities / SE, not exactly TD/SE
        # So D/E ≠ EM − 1 when there are non-debt liabilities. We show both for the course check.
        m["EM minus 1"] = (ta / se - 1) if se else None

        # ── Structural percentages (% of Total Assets) ────────────────────────
        if ta:
            for k in ["Intangible assets", "PP&E", "Other non-current assets",
                       "Inventories", "Accounts receivable", "Other current assets",
                       "Cash and cash equivalents"]:
                m[f"{k} %"] = data[k][y] / ta * 100
            m["NCA %"] = fa / ta * 100
            m["CA %"] = ca / ta * 100
            m["Equity %"] = se / ta * 100
            m["NCL %"] = ncl / ta * 100
            m["CL %"] = cl / ta * 100

        M[y] = m

    # YoY growth for raw items and computed aggregates
    for i, y in enumerate(yrs[:-1]):
        py = yrs[i + 1]
        for k in ["Total assets", "Total equity", "Total non-current assets",
                   "Total current assets", "Total non-current liabilities",
                   "Total current liabilities", "Inventories", "Cash and cash equivalents",
                   "Accounts receivable", "PP&E", "Borrowings non-current", "Borrowings current"]:
            c, p = data[k][y], data[k][py]
            M[y][f"{k} YoY"] = ((c - p) / abs(p) * 100) if p else None
        for k in ["WC", "WCN", "Net Cash", "Net Debt", "Capital Employed", "Invested Capital"]:
            c, p = M[y][k], M[py][k]
            M[y][f"{k} YoY"] = ((c - p) / abs(p) * 100) if p else None
    return M

# ════════════════════════════════════════════════════════════════════════════════
# HELPER FUNCTIONS
# ════════════════════════════════════════════════════════════════════════════════
def fm(v):
    """Thousands → Millions formatted string."""
    return f"€{v/1000:,.1f}M" if v is not None else "N/A"

def fr(v, d=2):
    return f"{v:.{d}f}" if v is not None else "N/A"

def fp(v):
    return f"{v:+.1f}%" if v is not None else "N/A"

def health(v, lo, hi, higher=True):
    if v is None: return "warning"
    if higher:
        return "good" if v >= lo else ("warning" if v >= lo * 0.7 else "danger")
    else:
        return "good" if v <= hi else ("warning" if v <= hi * 1.5 else "danger")

def h_icon(s):
    return {"good": "🟢", "warning": "🟡", "danger": "🔴"}.get(s, "⚪")

def card(label, value, bench="", h="good"):
    return (f'<div class="metric-card {h}"><div class="label">{label}</div>'
            f'<div class="value">{value}</div><div class="bench">{bench}</div></div>')

def plotly_layout(title="", h=420):
    return dict(
        title=dict(text=title, font=dict(size=16, color="#000")),
        template="plotly_white", height=h,
        font=dict(family="Arial, sans-serif", size=12),
        margin=dict(l=60, r=30, t=50, b=50),
        legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1),
    )

